# ==============================================================
#  FinAgent - Environment Variables Template
#  --------------------------------------------------------------
#  1. Copy this file:
#       Windows : copy .env.example .env
#       Linux   : cp .env.example .env
#  2. Fill in your actual API keys in .env
#  3. NEVER commit .env to version control
# ==============================================================

# --------------------------------------------------------------
# LLM Providers (GEMINI is the default provider)
# --------------------------------------------------------------

# Google Gemini [DEFAULT] - https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
# Optional multi-key failover (if key 1 fails/quota, agent tries next keys)
# GEMINI_API_KEYS=key_a,key_b,key_c
# GEMINI_API_KEY_1=key_a
# GEMINI_API_KEY_2=key_b
# GEMINI_API_KEY_3=key_c

# Anthropic Claude        - https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI GPT              - https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# --------------------------------------------------------------
# Financial Data Sources
# --------------------------------------------------------------

# NewsAPI                 - https://newsapi.org/register
NEWS_API_KEY=your_newsapi_key_here

# Alpha Vantage           - https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here
# FRED
FRED_API_KEY=
# --------------------------------------------------------------
# Pipeline Configuration (optional overrides)
# --------------------------------------------------------------

# Comma-separated list of default ticker symbols
# DEFAULT_TICKERS=AAPL,MSFT,GOOGL,NVDA

# Default LLM provider: gemini | anthropic | openai
# LLM_PROVIDER=gemini

# Log level: DEBUG | INFO | WARNING | ERROR
# LOG_LEVEL=INFO
